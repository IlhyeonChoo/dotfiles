prefix_rule(
  pattern=["rg"],
  decision="allow",
  justification="Shared repository exploration searches are allowed by default.",
  match=[
    "rg -n TODO src",
    "rg --files src",
    "rg -n -C 3 feature_flag .",
  ],
)

prefix_rule(
  pattern=["fd"],
  decision="allow",
  justification="Shared repository exploration file listing is allowed by default.",
  match=[
    "fd -tf src",
    "fd -E node_modules -E .git",
  ],
)

prefix_rule(
  pattern=["fdfind"],
  decision="allow",
  justification="Shared repository exploration file listing is allowed by default.",
  match=[
    "fdfind -tf src",
  ],
)

prefix_rule(
  pattern=["git", "grep"],
  decision="allow",
  justification="Tracked-file repository searches are allowed by default.",
  match=[
    "git grep -n ExactClassName",
  ],
)

prefix_rule(
  pattern=["git", "ls-files"],
  decision="allow",
  justification="Repository surface mapping is allowed by default.",
  match=[
    "git ls-files",
    "git ls-files src",
  ],
)

prefix_rule(
  pattern=["git", "check-ignore"],
  decision="allow",
  justification="Ignore-debug inspection is allowed by default.",
  match=[
    "git check-ignore -v path/to/file",
  ],
)

prefix_rule(
  pattern=["sg"],
  decision="allow",
  justification="Structural repository search is allowed by default.",
  match=[
    "sg -p 'foo($X)' src",
  ],
)

prefix_rule(
  pattern=["ctags"],
  decision="allow",
  justification="Symbol index generation is allowed by default.",
  match=[
    "ctags -R .",
  ],
)

prefix_rule(
  pattern=["repomix"],
  decision="allow",
  justification="Repository packaging for AI workflows is allowed by default.",
  match=[
    "repomix --compress",
  ],
)
